# =============================================================================
# Корневой .gitignore для проекта Diplomba (ВКР NIDS)
# =============================================================================

# -----------------------------------------------------------------------------
# Секреты / учётные данные (защитная сетка — даже если случайно положу)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*
credentials.json
secrets.*
*.secrets

# -----------------------------------------------------------------------------
# Python: кеши, байткод, пакеты, виртуальные окружения
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so

# Сборка / дистрибутивы
build/
dist/
*.egg-info/
*.egg
wheels/
*.whl

# Тестирование / линтеры
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pytype/
.dmypy.json
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Виртуальные окружения
.venv/
venv/
env/
ENV/
.python-version

# -----------------------------------------------------------------------------
# IDE / редакторы
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.spyderproject
.spyproject
.ropeproject

# -----------------------------------------------------------------------------
# ОС-мусор
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# Тяжёлые архивы и сторонний контент в корне
# (датасеты и стандарт ГОСТ — лицензионно нельзя перевыкладывать;
#  EXE-инсталлер — посторонний бинарник)
# -----------------------------------------------------------------------------
/cicids17.zip
/unsw.zip
/GitHubDesktopSetup-x64.exe
/gost_7.32-2017.pdf

# -----------------------------------------------------------------------------
# Сырые и обработанные датасеты (UNSW-NB15, CICIDS2017)
# В репозиторий идут только конфиги и схема; данные тянутся скриптами
# Stage3/scripts/01_download_*.py / 02_build_dataset.py
# -----------------------------------------------------------------------------
Stage3/data/cicids2017/
Stage3/data/unsw_nb15/
Stage3/data/processed/
Stage3/data/attacker_run.csv
Stage*/data/raw/
Stage*/data/interim/
Stage*/data/external/

# -----------------------------------------------------------------------------
# Обученные модели (десятки/сотни МБ; перетренируются скриптом 03_train.py)
# -----------------------------------------------------------------------------
Stage3/models/*.pt
Stage3/models/*.pth
Stage3/models/*.joblib
Stage3/models/*.pkl
Stage3/models/*.onnx
Stage*/models/*.pt
Stage*/models/*.pth
Stage*/models/*.joblib
Stage*/models/*.pkl
Stage*/models/*.onnx

# Чекпоинты тренировки
checkpoints/
*.ckpt

# -----------------------------------------------------------------------------
# Логи и временные файлы пайплайнов
# -----------------------------------------------------------------------------
*.log
logs/
Stage*/logs/
Stage*/experiments/runs/*/checkpoints/
mlruns/
wandb/
tensorboard/
runs/tensorboard/

# -----------------------------------------------------------------------------
# LaTeX: промежуточные артефакты сборки (PDF оставляем — это часть результата)
# -----------------------------------------------------------------------------
*.aux
*.bcf
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.lof
*.lot
*.out
*.run.xml
*.synctex.gz
*.synctex(busy)
*.toc
*.nav
*.snm
*.vrb
*.xdv
*.dvi
*.idx
*.ilg
*.ind
*.acn
*.acr
*.alg
*.glg
*.glo
*.gls
*.ist
texput.log
Report/report_simple.txt
Report/report_text.txt

# -----------------------------------------------------------------------------
# Прочие промежуточные результаты
# -----------------------------------------------------------------------------
*.tmp
*.bak
*.orig
*.rej
.cache/
